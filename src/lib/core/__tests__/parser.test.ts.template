import { describe, it, expect, beforeEach } from "vitest";
import { parseLatexTemplate } from "../parser";
import type { ParsedLatexTemplate } from "../../types";

/**
 * Test Template for parser.ts
 *
 * This template demonstrates the testing approach for the LaTeX parser.
 * Copy this file to parser.test.ts and fill in the implementation.
 *
 * Structure:
 * 1. Valid template parsing (happy path)
 * 2. Tag validation (fixed, fixed-options, separate-page)
 * 3. Tag conflicts (fixed + fixed-options)
 * 4. Invalid templates (error cases)
 * 5. Edge cases
 */

describe("parseLatexTemplate", () => {
  // ============================================================================
  // SECTION 1: Valid Template Parsing (Happy Path)
  // ============================================================================

  describe("Valid Templates", () => {
    it("should parse simple template with one MCQ question", () => {
      const latex = `
%{#setting}
% university=Test University
% groups=1
%{/setting}

%{#instructions}
% Read carefully
%{/instructions}

%% Question: Regular
What is 2 + 2?
%% Option:
Three
%% Option: *
Four
%% Option:
Five
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      // Assert: Template structure
      expect(result.settings).toBeDefined();
      expect(result.questions).toHaveLength(1);

      // Assert: Question content
      const question = result.questions[0];
      expect(question.text).toBe("What is 2 + 2?");
      expect(question.choices[0]).toHaveLength(3); // 3 options
      expect(question.choices[1]).toBe(1); // Correct answer index (Four)

      // Assert: No tags
      expect(question.fixed).toBe(false);
      expect(question.fixedOptions).toBe(false);
      expect(question.keepOnSeparatePage).toBe(false);
    });

    it("should parse template with multiple questions", () => {
      const latex = `
%{#setting}
% groups=3
%{/setting}

%% Question: Regular
Question 1?
%% Option: *
A
%% Option:
B
%% End Question

%% Question: Regular
Question 2?
%% Option:
X
%% Option: *
Y
%% End Question

%% Question: Regular
Question 3?
%% Option: *
Correct
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions).toHaveLength(3);
      expect(result.questions[0].text).toBe("Question 1?");
      expect(result.questions[1].text).toBe("Question 2?");
      expect(result.questions[2].text).toBe("Question 3?");

      // Verify correct answer indices
      expect(result.questions[0].choices[1]).toBe(0); // A
      expect(result.questions[1].choices[1]).toBe(1); // Y
      expect(result.questions[2].choices[1]).toBe(0); // Correct
    });

    it("should parse open-ended question (no options)", () => {
      const latex = `
%% Question: Regular
Explain photosynthesis.
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions).toHaveLength(1);
      expect(result.questions[0].text).toBe("Explain photosynthesis.");
      expect(result.questions[0].choices[0]).toHaveLength(0); // No options
    });

    it("should extract settings from settings block", () => {
      const latex = `
%{#setting}
% university=KFUPM
% department=Mathematics
% coursecode=MATH 101
% examname=Final Exam
% groups=10,10
%{/setting}

%% Question: Regular
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.settings).toBeDefined();
      expect(result.settings.university).toBe("KFUPM");
      expect(result.settings.department).toBe("Mathematics");
      expect(result.settings.coursecode).toBe("MATH 101");
      expect(result.settings.examname).toBe("Final Exam");
      expect(result.settings.groups).toBe("10,10");
    });

    it("should extract preamble commands", () => {
      const latex = `
%{#preamble}
\\usepackage{amsmath}
\\usepackage{tikz}
%{/preamble}

%% Question: Regular
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.preamble).toBeDefined();
      expect(result.preamble).toContain("\\usepackage{amsmath}");
      expect(result.preamble).toContain("\\usepackage{tikz}");
    });
  });

  // ============================================================================
  // SECTION 2: Tag Validation (Behavioral Modifiers)
  // ============================================================================

  describe("Tag Validation - Valid Tags", () => {
    it("should parse 'fixed' tag correctly", () => {
      const latex = `
%% Question: fixed
Student ID?
%% Option: *
Enter your ID
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].fixed).toBe(true);
      expect(result.questions[0].fixedOptions).toBe(false);
      expect(result.questions[0].keepOnSeparatePage).toBe(false);
    });

    it("should parse 'fixed-options' tag correctly", () => {
      const latex = `
%% Question: fixed-options
Which is correct?
%% Option:
A
%% Option: *
B
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].fixed).toBe(false);
      expect(result.questions[0].fixedOptions).toBe(true);
      expect(result.questions[0].keepOnSeparatePage).toBe(false);
    });

    it("should parse 'separate-page' tag correctly", () => {
      const latex = `
%% Question: separate-page
Long essay question.
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].fixed).toBe(false);
      expect(result.questions[0].fixedOptions).toBe(false);
      expect(result.questions[0].keepOnSeparatePage).toBe(true);
    });

    it("should parse multiple valid tags (fixed + separate-page)", () => {
      const latex = `
%% Question: fixed, separate-page
Cover page question.
%% Option: *
Answer
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].fixed).toBe(true);
      expect(result.questions[0].keepOnSeparatePage).toBe(true);
    });

    it("should parse tags with whitespace variations", () => {
      const latex = `
%% Question:   fixed  ,  separate-page
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].fixed).toBe(true);
      expect(result.questions[0].keepOnSeparatePage).toBe(true);
    });
  });

  // ============================================================================
  // SECTION 3: Tag Conflicts (Should Error)
  // ============================================================================

  describe("Tag Validation - Conflicts", () => {
    it("should reject 'fixed' + 'fixed-options' conflict", () => {
      const latex = `
%% Question: fixed, fixed-options
Invalid question?
%% Option: *
Answer
%% End Question
      `.trim();

      expect(() => parseLatexTemplate(latex)).toThrow(/cannot combine/i);
    });

    it("should provide context in conflict error message", () => {
      const latex = `
%% Question: Regular
Valid question 1?
%% Option: *
Yes
%% End Question

%% Question: fixed, fixed-options
Invalid question 2?
%% Option: *
Yes
%% End Question
      `.trim();

      expect(() => parseLatexTemplate(latex)).toThrow(/question 2/i);
    });

    it("should reject invalid tag names", () => {
      const latex = `
%% Question: invalid-tag
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      expect(() => parseLatexTemplate(latex)).toThrow(/invalid tag/i);
    });
  });

  // ============================================================================
  // SECTION 4: Invalid Templates (Error Handling)
  // ============================================================================

  describe("Invalid Templates - Error Cases", () => {
    it("should error on missing %% End Question marker", () => {
      const latex = `
%% Question: Regular
Test?
%% Option: *
Yes
      `.trim(); // Missing %% End Question

      expect(() => parseLatexTemplate(latex)).toThrow(/missing.*end question/i);
    });

    it("should error on missing correct answer marker (*)", () => {
      const latex = `
%% Question: Regular
Test?
%% Option:
A
%% Option:
B
%% End Question
      `.trim(); // No asterisk

      expect(() => parseLatexTemplate(latex)).toThrow(/correct answer/i);
    });

    it("should error on empty template", () => {
      const latex = "";

      expect(() => parseLatexTemplate(latex)).toThrow(/no questions/i);
    });

    it("should error on template with no questions", () => {
      const latex = `
%{#setting}
% groups=1
%{/setting}
      `.trim();

      expect(() => parseLatexTemplate(latex)).toThrow(/no questions/i);
    });

    it("should error on malformed settings block", () => {
      const latex = `
%{#setting}
% invalidformat
%{/setting}

%% Question: Regular
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      // This might be a warning or might be ignored - check actual implementation
      // For now, let's assume it parses but doesn't crash
      expect(() => parseLatexTemplate(latex)).not.toThrow();
    });

    it("should error on question without text", () => {
      const latex = `
%% Question: Regular
%% Option: *
Answer
%% End Question
      `.trim(); // No question text

      expect(() => parseLatexTemplate(latex)).toThrow(/empty question/i);
    });
  });

  // ============================================================================
  // SECTION 5: Edge Cases
  // ============================================================================

  describe("Edge Cases", () => {
    it("should handle question text with special LaTeX characters", () => {
      const latex = `
%% Question: Regular
What is $x^2 + y^2$?
%% Option: *
$x^2 + y^2$
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].text).toBe("What is $x^2 + y^2$?");
      expect(result.questions[0].choices[0][0].text).toContain("$x^2 + y^2$");
    });

    it("should handle multiline question text", () => {
      const latex = `
%% Question: Regular
This is a long question
that spans multiple lines
with proper formatting.
%% Option: *
Answer
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].text).toContain("multiple lines");
    });

    it("should not confuse %{#q} marker with tags", () => {
      // This is the bug that was fixed - question markers should not be matched by tag regex
      const latex = `
%{#q}
Some preamble content with %{#q} marker
%{/q}

%% Question: Regular
Test?
%% Option: *
Yes
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      // Should parse successfully without treating %{#q} as a tag
      expect(result.questions).toHaveLength(1);
    });

    it("should handle questions with many options (5+)", () => {
      const latex = `
%% Question: Regular
Multiple choice?
%% Option:
A
%% Option:
B
%% Option:
C
%% Option:
D
%% Option: *
E
%% Option:
F
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].choices[0]).toHaveLength(6);
      expect(result.questions[0].choices[1]).toBe(4); // E is correct
    });

    it("should handle template with only open-ended questions", () => {
      const latex = `
%% Question: Regular
Essay 1.
%% End Question

%% Question: Regular
Essay 2.
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions).toHaveLength(2);
      expect(result.questions[0].choices[0]).toHaveLength(0);
      expect(result.questions[1].choices[0]).toHaveLength(0);
    });

    it("should handle mixed MCQ and open-ended questions", () => {
      const latex = `
%% Question: Regular
MCQ question?
%% Option: *
A
%% Option:
B
%% End Question

%% Question: Regular
Open-ended question.
%% End Question

%% Question: Regular
Another MCQ?
%% Option: *
Yes
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions).toHaveLength(3);
      expect(result.questions[0].choices[0].length).toBeGreaterThan(0); // MCQ
      expect(result.questions[1].choices[0].length).toBe(0); // Open-ended
      expect(result.questions[2].choices[0].length).toBeGreaterThan(0); // MCQ
    });

    it("should preserve option order as written", () => {
      const latex = `
%% Question: Regular
Order test?
%% Option:
First
%% Option:
Second
%% Option: *
Third
%% End Question
      `.trim();

      const result = parseLatexTemplate(latex);

      expect(result.questions[0].choices[0][0].text).toBe("First");
      expect(result.questions[0].choices[0][1].text).toBe("Second");
      expect(result.questions[0].choices[0][2].text).toBe("Third");
      expect(result.questions[0].choices[1]).toBe(2); // Third is correct
    });
  });

  // ============================================================================
  // SECTION 6: Integration with Tag Validator
  // ============================================================================

  describe("Integration - Tag Validator", () => {
    it("should use tag validator for validation", () => {
      // The parser should delegate to tag-validator.ts
      const latex = `
%% Question: fixed, fixed-options
Conflict test.
%% Option: *
Answer
%% End Question
      `.trim();

      // Should throw the same error as tag-validator.ts would
      expect(() => parseLatexTemplate(latex)).toThrow();
    });

    it("should collect all tag errors before throwing", () => {
      const latex = `
%% Question: invalid-tag-1
Question 1?
%% Option: *
A
%% End Question

%% Question: invalid-tag-2
Question 2?
%% Option: *
B
%% End Question
      `.trim();

      try {
        parseLatexTemplate(latex);
        expect.fail("Should have thrown");
      } catch (error: any) {
        // Should contain errors for both questions
        expect(error.message).toContain("Question 1");
        expect(error.message).toContain("Question 2");
      }
    });
  });
});

// ============================================================================
// HELPER FUNCTIONS (Optional - for cleaner tests)
// ============================================================================

/**
 * Helper: Create a minimal valid LaTeX template
 */
function createMinimalTemplate(questionText: string, tags?: string): string {
  return `
%% Question: ${tags || "Regular"}
${questionText}
%% Option: *
Answer
%% End Question
  `.trim();
}

/**
 * Helper: Create template with multiple questions
 */
function createTemplateWithQuestions(count: number): string {
  const questions = Array.from({ length: count }, (_, i) => `
%% Question: Regular
Question ${i + 1}?
%% Option: *
Answer ${i + 1}
%% End Question
  `).join("\n");

  return `
%{#setting}
% groups=${count}
%{/setting}

${questions}
  `.trim();
}

